# Copy this file to .env.local and fill in your key.
# .env.local is gitignored and will never be committed.

# OpenRouter — one key, every model (Anthropic, OpenAI, Google, etc.)
# Get one at https://openrouter.ai/keys
VITE_OPENROUTER_API_KEY=

# Supabase (paid-tier backend; optional in Phase 0 / free tier).
# Browser-safe: the anon key is publishable — access is governed by RLS.
# For a local stack: `supabase start` prints both values.
# The service-role key is NEVER put here — it stays server-side only.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
